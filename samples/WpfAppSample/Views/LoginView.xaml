<UserControl x:Class="WpfAppSample.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModels="clr-namespace:WpfAppSample.ViewModels"
             xmlns:wpfAppSample="clr-namespace:WpfAppSample"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance {x:Type viewModels:LoginViewModel}, IsDesignTimeCreatable=True}"
             d:DesignHeight="250" d:DesignWidth="400"
             MinWidth="400"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             DataContextChanged="UserControl_DataContextChanged">

    <UserControl.Resources>
        <!-- Base style for input fields -->
        <Style x:Key="LoginFieldBaseStyle" TargetType="Control">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#E81123"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="ToolTip"
                            Value="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox/PasswordBox styles -->
        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource LoginFieldBaseStyle}"/>
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource LoginFieldBaseStyle}"/>

    </UserControl.Resources>

    <!-- Enter = Login, Esc = Cancel -->
    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="16" FocusManager.FocusedElement="{Binding ElementName=UserNameBox}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- title -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>   <!-- username -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>   <!-- password -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>   <!-- remember me -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>   <!-- actions area (errors + hint + buttons) -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Grid.ColumnSpan="2"
                   Text="{x:Static wpfAppSample:Loc.Sign_in}"
                   FontSize="20" FontWeight="SemiBold"/>

        <!-- Username label -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="{x:Static wpfAppSample:Loc.User_name}"/>

        <!-- Username field + error text -->
        <Grid Grid.Row="2" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="UserNameBox"
                     Grid.Row="0"
                     Style="{StaticResource LoginTextBoxStyle}"
                     Text="{Binding UserName,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    ValidatesOnNotifyDataErrors=True}"/>

            <!-- Delayed binding to [0] only when HasError == True -->
            <TextBlock Grid.Row="1" Margin="0,3,0,0"
                       Foreground="#CC0000"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=UserNameBox, Path=(Validation.HasError)}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Text"
                                        Value="{Binding ElementName=UserNameBox, Path=(Validation.Errors)[0].ErrorContent}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Password label -->
        <TextBlock Grid.Row="4" Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="{x:Static wpfAppSample:Loc.Password}"/>

        <!-- Password field + error text -->
        <Grid Grid.Row="4" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <PasswordBox x:Name="PasswordBoxControl"
                         Grid.Row="0"
                         Style="{StaticResource LoginPasswordBoxStyle}"
                         wpfAppSample:PasswordBoxHelper.BindPassword="True"
                         wpfAppSample:PasswordBoxHelper.Password="{Binding Password,
                                        Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged,
                                        ValidatesOnNotifyDataErrors=True}"/>

            <!-- Delayed binding to [0] only when HasError == True -->
            <TextBlock Grid.Row="1" Margin="0,3,0,0"
                       Foreground="#CC0000"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=PasswordBoxControl, Path=(Validation.HasError)}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Text"
                                        Value="{Binding ElementName=PasswordBoxControl, Path=(Validation.Errors)[0].ErrorContent}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Remember me -->
        <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="{x:Static wpfAppSample:Loc.Remember_me}"
                  IsChecked="{Binding RememberMe, Mode=TwoWay}" />

        <!-- Actions area: stacked into own Grid to avoid overlap -->
        <Grid Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- entity-level errors + hint -->
                <RowDefinition Height="Auto"/>  <!-- buttons -->
            </Grid.RowDefinitions>

            <!-- Hidden host subscribing to entity-level INotifyDataErrorInfo -->
            <TextBlock x:Name="EntityErrorHost"
                       Visibility="Collapsed"
                       Focusable="False"
                       IsHitTestVisible="False"
                       Validation.ErrorTemplate="{x:Null}">
                <TextBlock.Text>
                    <!-- Bind to the VM itself; ValidatesOnNotifyDataErrors wires entity-level errors -->
                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}"
                             Path="DataContext"
                             Mode="OneWay"
                             ValidatesOnNotifyDataErrors="True"/>
                </TextBlock.Text>
            </TextBlock>

            <!-- Top stack: entity-level error banner, then hint -->
            <StackPanel Grid.Row="0" Orientation="Vertical">
                <!-- Entity-level error banner -->
                <Border CornerRadius="4"
                        Padding="8"
                        Margin="0,0,0,8"
                        Background="#FFF8D7"
                        BorderBrush="#F1C21B"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=EntityErrorHost, Path=(Validation.HasError)}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <!-- Show all entity-level errors -->
                    <ItemsControl ItemsSource="{Binding ElementName=EntityErrorHost, Path=(Validation.Errors)}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="#8A6D3B" TextWrapping="Wrap" Text="{Binding ErrorContent}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>

                <!-- Hint text -->
                <TextBlock Text="admin/admin, user/pass, locked/any"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>
            </StackPanel>

            <!-- Right-aligned buttons -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="{x:Static wpfAppSample:Loc.Cancel}"
                        Margin="0,0,12,0"
                        Padding="12,6"
                        MinHeight="32"
                        MinWidth="96"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"/>
                <Button Content="{x:Static wpfAppSample:Loc.Sign_in}"
                        Padding="12,6"
                        MinHeight="32"
                        MinWidth="96"
                        Command="{Binding LoginCommand}"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
